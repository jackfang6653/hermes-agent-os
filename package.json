{
  "name": "hermes-agent-os",
  "version": "1.0.0",
  "private": true,
  "description": "Hermes Agent OS — 多智能体团队协作开发系统",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "cli": "pnpm --filter @hermes-os/core cli",
    "serve": "pnpm --filter @hermes-os/core cli -- serve",
    "start": "node packages/backend/dist/server.js",
    "setup": "node scripts/setup.js",
    "bootstrap": "node scripts/bootstrap.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
